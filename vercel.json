{
  "redirects": [
    {
      "source": "/:path*",
      "has": [
        { "type": "host", "value": "www.ilika.in" }
      ],
      "destination": "https://ilika.in/:path*",
      "permanent": true
    },
    {
      "source": "/sitemap.xml/",
      "destination": "/sitemap.xml",
      "permanent": true
    },
    {
      "source": "/robots.txt/",
      "destination": "/robots.txt",
      "permanent": true
    },
    {
      "source": "/googleb361cfb7dba6801e.html/",
      "destination": "/googleb361cfb7dba6801e.html",
      "permanent": true
    }
  ],
  "rewrites": [
    { "source": "/wp-content/(.*)", "destination": "/api/not-found?status=410" },
    { "source": "/wp-admin/(.*)", "destination": "/api/not-found?status=410" },
    { "source": "/wp-includes/(.*)", "destination": "/api/not-found?status=410" },
    { "source": "/xmlrpc.php", "destination": "/api/not-found?status=410" },
    { "source": "/(1win.*)", "destination": "/api/not-found?status=410" },
    { "source": "/.well-known/:path*", "destination": "/.well-known/:path*" },
    { "source": "/sitemap.xml", "destination": "/sitemap.xml" },
    { "source": "/sitemap.html", "destination": "/sitemap.html" },
    { "source": "/robots.txt", "destination": "/robots.txt" },
    { "source": "/llms.txt", "destination": "/llms.txt" },
    { "source": "/llms-full.txt", "destination": "/llms-full.txt" },
    { "source": "/googleb361cfb7dba6801e.html", "destination": "/googleb361cfb7dba6801e.html" },
    { "source": "/(.*)", "destination": "/index.html" }
  ],
  "headers": [
    {
      "source": "/assets/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    },
    {
      "source": "/Images/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=2592000, stale-while-revalidate=86400" }
      ]
    },
    {
      "source": "/favicon.ico",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=2592000, stale-while-revalidate=86400" }
      ]
    },
    {
      "source": "/sitemap.xml",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=3600, stale-while-revalidate=86400" }
      ]
    },
    {
      "source": "/robots.txt",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=3600, stale-while-revalidate=86400" }
      ]
    },
    {
      "source": "/index.html",
      "headers": [
        { "key": "Cache-Control", "value": "no-cache, no-store, must-revalidate" },
        { "key": "Pragma", "value": "no-cache" },
        { "key": "Expires", "value": "0" }
      ]
    },
    {
      "source": "/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=0, must-revalidate" }
      ]
    }
  ]
}
